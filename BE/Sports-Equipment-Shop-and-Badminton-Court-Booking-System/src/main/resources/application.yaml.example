spring:
  application:
    name: system
  datasource:
    url: jdbc:postgresql://localhost:5432/postgres
    username: postgres
    password: admin
    driver-class-name: org.postgresql.Driver
    hikari:
      maximum-pool-size: 10
      minimum-idle: 2
      idle-timeout: 30000
      connection-timeout: 30000
      max-lifetime: 1800000
      pool-name: SportSystemPool
  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true
    properties:
      hibernate:
        format_sql: true
    database-platform: org.hibernate.dialect.PostgreSQLDialect
  mail:
    host: smtp.gmail.com
    port: 587
    username: hoangvudx2004@gmail.com
    password: ezrhnhtdsnejmawi
    properties:
      mail:
        smtp:
          auth: true
          starttls:
            enable: true
          starttls.required: true
  elasticsearch:
    uris: http://localhost:9200
  messages:
    basename: messages
    encoding: UTF-8
    fallback-to-system-locale: false

server:
  port: 8086

jwt:
  signerKey:
  valid-duration: 360000
  refreshable-duration: 36000

stripe:
  secret-key:
  webhook-secret: